<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurant Le Village - Annaba</title>
    <!-- خط فاخر وعريق للعناوين وخط مرن للنصوص -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #1a1512; /* بني داكن فاخر مستوحى من الموقد والديكور الخشبي */
            --card-bg: #261f1a;
            --primary-gold: #c59d5f; /* ذهبي دافئ يعكس الفخامة والعراقة */
            --text-light: #f4edd9; /* بيج ناعم ومريح للعين بالقراءة */
            --text-muted: #bfa89e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-light);
            line-height: 1.6;
        }

        /* Hero Section */
        .hero {
            padding: 60px 20px;
            text-align: center;
            border-bottom: 2px solid var(--primary-gold);
            background: linear-gradient(rgba(26, 21, 18, 0.85), rgba(26, 21, 18, 0.95));
        }

        .logo-placeholder {
            width: 120px;
            height: 120px;
            border: 2px dashed var(--primary-gold);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: var(--primary-gold);
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            color: var(--primary-gold);
            margin-bottom: 10px;
        }

        .tagline {
            font-style: italic;
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 5px;
        }

        .since {
            font-size: 0.9rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--primary-gold);
            margin-bottom: 25px;
        }

        /* Menu Section */
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px 100px;
        }

        h2 {
            font-family: 'Playfair Display', serif;
            text-align: center;
            font-size: 2rem;
            color: var(--primary-gold);
            margin-bottom: 30px;
            position: relative;
        }

        h2::after {
            content: '';
            display: block;
            width: 50px;
            height: 2px;
            background-color: var(--primary-gold);
            margin: 10px auto 0;
        }

        .menu-category {
            margin-bottom: 40px;
        }

        .menu-item {
            background-color: var(--card-bg);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid var(--primary-gold);
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }

        .item-info h3 {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text-light);
        }

        .item-price {
            font-family: 'Playfair Display', serif;
            color: var(--primary-gold);
            font-weight: bold;
            font-size: 1.1rem;
            white-space: nowrap;
            margin-left: 15px;
        }

        /* Sticky Call to Action Bar for Mobile */
        .cta-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: var(--card-bg);
            border-top: 1px solid var(--primary-gold);
            padding: 15px;
            display: flex;
            gap: 10px;
            z-index: 1000;
        }

        .btn {
            flex: 1;
            text-align: center;
            padding: 12px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .btn-whatsapp {
            background-color: #25D366;
            color: #fff;
        }

        .btn-call {
            background-color: transparent;
            color: var(--primary-gold);
            border: 1px solid var(--primary-gold);
        }

        /* Footer Info */
        .footer-info {
            text-align: center;
            padding: 20px;
            background-color: #110e0c;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-top: 1px solid rgba(197, 157, 95, 0.2);
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <section class="hero">
        <div class="logo-placeholder">
            [ Logo le Village ]
        </div>
        <h1>Le Village</h1>
        <p class="tagline">La Famille Tunisienne & Annabie</p>
        <p class="since">Depuis 1988</p>
    </section>

    <!-- Main Container / Menu -->
    <div class="container">
        <h2>Les Entrées</h2>
        
        <div class="menu-category">
            <!-- البينات مستخرجة بدقة من قائمة الطعام الرسمية للمطعم -->
            <div class="menu-item">
                <div class="item-info">
                    <h3>Soupe Frik ou Poisson</h3>
                </div>
                <div class="item-price">500 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Soupe Borgol</h3>
                </div>
                <div class="item-price">500 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Bourak Annabi et Tunisien</h3>
                </div>
                <div class="item-price">350 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Soupe de Poisson</h3>
                </div>
                <div class="item-price">600 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Salade Mechouiya</h3>
                </div>
                <div class="item-price">350 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Salade César</h3>
                </div>
                <div class="item-price">750 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Salade Tunisienne</h3>
                </div>
                <div class="item-price">300 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Salade Poulpe</h3>
                </div>
                <div class="item-price">700 DA</div>
            </div>

            <div class="menu-item">
                <div class="item-info">
                    <h3>Salade Mixte Fruits de Mer</h3>
                </div>
                <div class="item-price">700 DA</div>
            </div>
        </div>
    </div>

    <!-- Footer Information Section -->
    <div class="footer-info">
        <p>📍 31 Bd Saouli Abdelkader, Annaba</p>
        <p>🕒 Ouvert de 11:30 à Minuit</p>
    </div>

    <!-- Sticky Bottom Bar for Mobile Buttons -->
    <div class="cta-bar">
        <!-- زر اتصال مباشر برقم المطعم المستخرج -->
        <a href="tel:0561796943" class="btn btn-call">📞 Appeler</a>
        <!-- زر حجز مباشر ومجهز عبر الواتساب -->
        <a href="https://wa.me/213561796943?text=Bonjour%20Le%20Village,%20je%20souhaite%20réserver%20une%20table" target="_blank" class="btn btn-whatsapp">💬 Réserver via WhatsApp</a>
    </div>

</body>
</html>
